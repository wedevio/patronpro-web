n      border:none;\n      color:#fff;\n      padding:10px;\n      cursor:pointer;\n    }\n\n    .hero{\n      position:relative;\n      background-color:var(--primary);\n      background-image:url('{{custom_values.website_hero_image}}');\n      background-size:cover;\n      background-position:center;\n      margin-top:88px;\n    }\n    .hero::before{\n      content:\"\";\n      position:absolute;\n      inset:0;\n      background:rgba(0,0,0,.58);\n    }\n    .hero-inner{\n      position:relative;\n      z-index:1;\n      max-width:1200px;\n      margin:0 auto;\n      padding:86px 24px 76px;\n      display:grid;\n      grid-template-columns:1.2fr .8fr;\n      gap:32px;\n      align-items:center;\n    }\n    .hero p{\n      color:rgba(255,255,255,.92);\n      max-width:680px;\n      font-size:1.05rem;\n    }\n    .hero-actions{\n      display:flex;\n      flex-wrap:wrap;\n      gap:14px;\n      margin:26px 0 30px;\n    }\n    .stats{\n      display:grid;\n      grid-template-columns:repeat(4,1fr);\n      gap:14px;\n    }\n    .stat{\n      background:rgba(255,255,255,.08);\n      border-left:4px solid var(--accent);\n      padding:16px;\n      backdrop-filter:blur(2px);\n    }\n    .stat strong{\n      display:block;\n      color:#fff;\n      font-family:'Oswald',sans-serif;\n      font-size:1.7rem;\n      line-height:1;\n      margin-bottom:6px;\n    }\n    .stat span{\n      color:rgba(255,255,255,.86);\n      font-size:.92rem;\n    }\n    .hero-card{\n      background:rgba(255,255,255,.96);\n      padding:28px;\n      box-shadow:var(--shadow);\n      border-top:6px solid var(--accent);\n    }\n    .hero-card h3{\n      margin-bottom:10px;\n    }\n    .hero-list{\n      display:grid;\n      gap:14px;\n      margin:20px 0 24px;\n    }\n    .hero-list-item{\n      display:flex;\n      gap:12px;\n      align-items:flex-start;\n    }\n    .hero-list-item i{\n      color:var(--accent);\n      flex:0 0 auto;\n      margin-top:2px;\n    }\n\n    .trust-band{\n      background:#231013;\n      color:#fff;\n      padding:22px 0;\n    }\n    .trust-grid{\n      display:grid;\n      grid-template-columns:repeat(5,1fr);\n      gap:18px;\n    }\n    .trust-item{\n      display:flex;\n      align-items:center;\n      gap:12px;\n      padding:8px 6px;\n    }\n    .trust-item i{\n      color:var(--accent);\n      width:24px;\n      height:24px;\n      flex:0 0 auto;\n    }\n    .trust-item span{\n      font-size:.95rem;\n      font-weight:600;\n      line-height:1.35;\n    }\n\n    .services-grid,\n    .testimonials-grid{\n      display:grid;\n      grid-template-columns:repeat(3,1fr);\n      gap:22px;\n      margin-top:24px;\n    }\n    .card{\n      background:var(--surface);\n      border-left:4px solid var(--primary);\n      padding:24px;\n      box-shadow:var(--shadow);\n      transition:.25s ease;\n    }\n    .card:hover{\n      transform:translateY(-5px);\n      box-shadow:0 16px 32px rgba(0,0,0,.12);\n    }\n    .card .icon-wrap{\n      width:54px;\n      height:54px;\n      display:grid;\n      place-items:center;\n      background:rgba(246,147,9,.14);\n      color:var(--accent);\n      margin-bottom:16px;\n    }\n\n    .about-grid{\n      display:grid;\n      grid-template-columns:1fr 1fr;\n      gap:34px;\n      align-items:center;\n      margin-top:24px;\n    }\n    .about-image{\n      min-height:420px;\n      background-color:var(--primary);\n      background-image:url('{{custom_values.website_about_image}}');\n      background-size:cover;\n      background-position:center;\n      position:relative;\n      box-shadow:var(--shadow);\n    }\n    .about-image::before{\n      content:\"\";\n      position:absolute;\n      inset:0;\n      background:linear-gradient(180deg, rgba(0,0,0,.15), rgba(0,0,0,.35));\n    }\n    .about-points{\n      display:grid;\n      gap:14px;\n      margin-top:20px;\n    }\n    .about-point{\n      display:flex;\n      gap:12px;\n      align-items:flex-start;\n      padding:14px 0;\n      border-bottom:1px solid var(--border);\n    }\n    .about-point i{\n      color:var(--accent);\n      margin-top:2px;\n    }\n    .hours-box{\n      margin-top:22px;\n      padding:18px;\n      background:var(--bg-soft);\n      border-left:4px solid var(--accent);\n    }\n\n    .process-grid{\n      display:grid;\n      grid-template-columns:repeat(4,1fr);\n      gap:20px;\n      margin-top:28px;\n    }\n    .process-step{\n      background:#fff;\n      padding:24px;\n      border-left:4px solid var(--accent);\n      box-shadow:var(--shadow);\n      position:relative;\n    }\n    .step-number{\n      font-family:'Oswald',sans-serif;\n      font-size:2rem;\n      color:var(--primary);\n      margin-bottom:10px;\n    }\n\n    .testimonial{\n      background:#fff;\n      padding:24px;\n      box-shadow:var(--shadow);\n      border-left:4px solid var(--accent);\n    }\n    .stars{\n      color:var(--accent);\n      font-size:1.1rem;\n      letter-spacing:.08em;\n      margin-bottom:10px;\n    }\n    .testimonial strong{\n      color:var(--primary);\n      display:block;\n      margin-top:12px;\n    }\n\n    .urgent-cta{\n      position:relative;\n      background-color:#151515;\n      background-image:url('{{custom_values.website_contact_image}}');\n      background-size:cover;\n      background-position:center;\n      color:#fff;\n    }\n    .urgent-cta::before{\n      content:\"\";\n      position:absolute;\n      inset:0;\n      background:rgba(0,0,0,.68);\n    }\n    .urgent-inner{\n      position:relative;\n      z-index:1;\n      max-width:1200px;\n      margin:0 auto;\n      padding:72px 24px;\n      text-align:center;\n    }\n    .urgent-inner h2,\n    .urgent-inner p{\n      color:#fff;\n    }\n    .urgent-phone{\n      display:inline-block;\n      margin:18px 0 22px;\n      font-family:'Oswald',sans-serif;\n      font-size:clamp(2rem,4vw,3rem);\n      color:var(--accent);\n    }\n\n    .contact-grid{\n      display:grid;\n      grid-template-columns:.95fr 1.05fr;\n      gap:28px;\n      margin-top:24px;\n    }\n    .contact-info,\n    .contact-form{\n      background:#fff;\n      padding:26px;\n      box-shadow:var(--shadow);\n      border-left:4px solid var(--primary);\n    }\n    .contact-item{\n      display:flex;\n      gap:12px;\n      align-items:flex-start;\n      margin-bottom:18px;\n    }\n    .contact-item i{\n      color:var(--accent);\n      margin-top:2px;\n      flex:0 0 auto;\n    }\n    .contact-item a{\n      color:var(--primary);\n      font-weight:700;\n    }\n\n    footer{\n      background:var(--primary);\n      color:#fff;\n      padding:34px 0;\n    }\n    .footer-grid{\n      display:grid;\n      grid-template-columns:1.1fr .9fr .8fr;\n      gap:24px;\n      align-items:start;\n    }\n    .footer-links a,\n    .footer-contact a{\n      display:block;\n      color:#fff;\n      margin-bottom:10px;\n    }\n    .footer-links a:hover,\n    .footer-contact a:hover{\n      color:var(--accent);\n    }\n    .footer-logo{\n      margin-bottom:14px;\n    }\n\n    .fade-in{\n      opacity:0;\n      transform:translateY(24px);\n      transition:opacity .7s ease, transform .7s ease;\n    }\n    .fade-in.visible{\n      opacity:1;\n      transform:translateY(0);\n    }\n\n    @media (max-width: 991px){\n      .hero-inner,\n      .about-grid,\n      .contact-grid{\n        grid-template-columns:1fr;\n      }\n      .stats,\n      .services-grid,\n      .testimonials-grid,\n      .process-grid,\n      .trust-grid,\n      .footer-grid{\n        grid-template-columns:1fr 1fr;\n      }\n      .hero-card{\n        max-width:700px;\n      }\n      .nav-links,\n      .nav-cta{\n        display:none;\n      }\n      .mobile-toggle{\n        display:block;\n      }\n      .mobile-menu{\n        display:none;\n        padding:0 0 18px;\n      }\n      .mobile-menu.open{\n        display:block;\n      }\n      .mobile-menu a{\n        display:block;\n        color:#fff;\n        padding:12px 0;\n        border-top:1px solid rgba(255,255,255,.12);\n        font-weight:600;\n      }\n      .mobile-menu .btn{\n        width:100%;\n        margin-top:14px;\n      }\n    }\n\n    @media (max-width: 640px){\n      .section{padding:58px 0}\n      .hero-inner{padding:64px 20px 58px}\n      .stats,\n      .services-grid,\n      .testimonials-grid,\n      .process-grid,\n      .trust-grid,\n      .footer-grid{\n        grid-template-columns:1fr;\n      }\n      .trust-item{\n        padding:10px 0;\n      }\n      .hero p{\n        font-size:1rem;\n      }\n      h1{\n        font-size:clamp(1.9rem,8vw,2.2rem);\n      }\n    }\n  </style>\n</head>\n<body>\n  <script src=\"https://unpkg.com/lucide@latest/dist/umd/lucide.js\"></script>\n\n  <header class=\"topbar\">\n    <div class=\"container\">\n      <nav class=\"nav\">\n        <a href=\"#inicio\" class=\"nav-logo\" aria-label=\"Inicio\">\n          <img src=\"{{custom_values.logo}}\" alt=\"{{custom_values.company_name}}\" style=\"height:76px;width:auto;object-fit:contain;filter:brightness(0) invert(1) contrast(200%);\" onerror=\"this.style.display='none';this.nextElementSibling.style.display='block'\">\n          <span style=\"display:none;font-weight:700;font-size:1.1rem;color:#fff;\">{{custom_values.company_name}}</span>\n        </a>\n\n        <div class=\"nav-links\">\n          <a href=\"#servicios\">Servicios</a>\n          <a href=\"#nosotros\">Nosotros</a>\n          <a href=\"#proceso\">Proceso</a>\n          <a href=\"#testimonios\">Reseñas</a>\n          <a href=\"#contacto\">Contacto</a>\n        </div>\n\n        <div class=\"nav-cta\">\n          <a class=\"btn btn-accent\" href=\"tel:{{custom_values.company_phone}}\">\n            <i data-lucide=\"phone-call\" style=\"width:18px;height:18px;\"></i>\n            Llamar ahora\n          </a>\n        </div>\n\n        <button class=\"mobile-toggle\" aria-label=\"Abrir menú\" aria-expanded=\"false\">\n          <i data-lucide=\"menu\" style=\"width:30px;height:30px;\"></i>\n        </button>\n      </nav>\n\n      <div class=\"mobile-menu\" id=\"mobileMenu\">\n        <a href=\"#servicios\">Servicios</a>\n        <a href=\"#nosotros\">Nosotros</a>\n        <a href=\"#proceso\">Proceso</a>\n        <a href=\"#testimonios\">Reseñas</a>\n        <a href=\"#contacto\">Contacto</a>\n        <a class=\"btn btn-accent\" href=\"tel:{{custom_values.company_phone}}\">\n          <i data-lucide=\"phone-call\" style=\"width:18px;height:18px;\"></i>\n          Llamar ahora\n        </a>\n      </div>\n    </div>\n  </header>\n\n  <section class=\"hero\" id=\"inicio\">\n    <div class=\"hero-inner\">\n      <div class=\"fade-in\">\n        <span class=\"eyebrow\">Roofing en Glendale</span>\n        <h1>Tu techo, hecho para aguantar sol, lluvia y años de uso</h1>\n        <p>Llevamos 10 años haciendo techos en Glendale. Trabajo garantizado, precio justo. Si necesita reparación, reemplazo o mantenimiento, en Picturelle le damos una respuesta clara y una cotización sin rodeos.</p>\n\n        <div class=\"hero-actions\">\n          <a class=\"btn btn-accent\" href=\"tel:{{custom_values.company_phone}}\">\n            <i data-lucide=\"phone-call\" style=\"width:18px;height:18px;\"></i>\n            Llamar al {{custom_values.company_phone}}\n          </a>\n          <a class=\"btn btn-outline\" href=\"#contacto\">\n            <i data-lucide=\"clipboard-list\" style=\"width:18px;height:18px;\"></i>\n            Pedir cotización\n          </a>\n        </div>\n\n        <div class=\"stats\">\n          <div class=\"stat\">\n            <strong>10+</strong>\n            <span>Años atendiendo trabajos de techado</span>\n          </div>\n          <div class=\"stat\">\n            <strong>24 h</strong>\n            <span>Presupuesto gratis en poco tiempo</span>\n          </div>\n          <div class=\"stat\">\n            <strong>Por escrito</strong>\n            <span>Trabajo garantizado y claro</span>\n          </div>\n          <div class=\"stat\">\n            <strong>Sin sorpresas</strong>\n            <span>Precio explicado antes de empezar</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"hero-card fade-in\">\n        <h3>¿Qué necesita su techo hoy?</h3>\n        <p class=\"muted\">Atendemos trabajos residenciales y comerciales con enfoque práctico: revisar, explicar el problema y resolverlo bien desde la primera visita.</p>\n\n        <div class=\"hero-list\">\n          <div class=\"hero-list-item\">\n            <i data-lucide=\"shield-check\" style=\"width:22px;height:22px;\"></i>\n            <div><strong>Trabajo garantizado</strong><br><span class=\"muted\">Le dejamos claro qué se hizo y qué cubre la garantía.</span></div>\n          </div>\n          <div class=\"hero-list-item\">\n            <i data-lucide=\"clock-3\" style=\"width:22px;height:22px;\"></i>\n            <div><strong>Llegamos a tiempo o le avisamos</strong><br><span class=\"muted\">Comunicación directa, sin hacerlo esperar todo el día.</span></div>\n          </div>\n          <div class=\"hero-list-item\">\n            <i data-lucide=\"home\" style=\"width:22px;height:22px;\"></i>\n            <div><strong>Techos residenciales y comerciales</strong><br><span class=\"muted\">Desde fugas pequeñas hasta reemplazos completos.</span></div>\n          </div>\n        </div>\n\n        <a class=\"btn btn-primary\" href=\"#contacto\">\n          <i data-lucide=\"file-text\" style=\"width:18px;height:18px;\"></i>\n          Solicitar evaluación\n        </a>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"trust-band\">\n    <div class=\"container\">\n      <div class=\"trust-grid fade-in\">\n        <div class=\"trust-item\">\n          <i data-lucide=\"badge-check\"></i>\n          <span>Trabajo garantizado por escrito</span>\n        </div>\n        <div class=\"trust-item\">\n          <i data-lucide=\"hammer\"></i>\n          <span>10 años en trabajos de roofing</span>\n        </div>\n        <div class=\"trust-item\">\n          <i data-lucide=\"map-pinned\"></i>\n          <span>Servicio en Glendale y zonas cercanas</span>\n        </div>\n        <div class=\"trust-item\">\n          <i data-lucide=\"clipboard-check\"></i>\n          <span>Presupuesto claro y sin sorpresas</span>\n        </div>\n        <div class=\"trust-item\">\n          <i data-lucide=\"timer-reset\"></i>\n          <span>Respuesta rápida para fugas y daños</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section section-alt\" id=\"servicios\">\n    <div class=\"container\">\n      <div class=\"fade-in\">\n        <span class=\"eyebrow\">Servicios</span>\n        <h2>Servicios de roofing para proteger su propiedad</h2>\n        <p class=\"muted\">Si el techo ya presenta filtraciones, tejas dañadas o desgaste por el clima, hacemos el trabajo necesario con materiales adecuados y tiempos realistas.</p>\n      </div>\n\n      <div class=\"services-grid\">\n        <div class=\"card fade-in\">\n          <div class=\"icon-wrap\"><i data-lucide=\"house\"></i></div>\n          <h3>Reemplazo de techo</h3>\n          <p>Quitamos el sistema viejo y colocamos un techo nuevo, bien instalado y listo para durar.</p>\n        </div>\n\n        <div class=\"card fade-in\">\n          <div class=\"icon-wrap\"><i data-lucide=\"wrench\"></i></div>\n          <h3>Reparación de fugas</h3>\n          <p>Detectamos el punto del problema y lo reparamos antes de que dañe plafones, paredes o estructura.</p>\n        </div>\n\n        <div class=\"card fade-in\">\n          <div class=\"icon-wrap\"><i data-lucide=\"search-check\"></i></div>\n          <h3>Inspección de techo</h3>\n          <p>Revisamos el estado general del techo y le explicamos qué necesita atención inmediata y qué puede esperar.</p>\n        </div>\n\n        <div class=\"card fade-in\">\n          <div class=\"icon-wrap\"><i data-lucide=\"cloud-rain-wind\"></i></div>\n          <h3>Daños por tormenta</h3>\n          <p>Atendemos techos afectados por viento, lluvia intensa o ramas caídas para evitar más filtraciones.</p>\n        </div>\n\n        <div class=\"card fade-in\">\n          <div class=\"icon-wrap\"><i data-lucide=\"building-2\"></i></div>\n          <h3>Roofing comercial</h3>\n          <p>Trabajos en propiedades comerciales con enfoque en seguridad, tiempos claros y mínima interrupción.</p>\n        </div>\n\n        <div class=\"card fade-in\">\n          <div class=\"icon-wrap\"><i data-lucide=\"shield\"></i></div>\n          <h3>Mantenimiento preventivo</h3>\n          <p>Revisiones y ajustes para alargar la vida del techo y detectar problemas antes de que salgan caros.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section\" id=\"nosotros\">\n    <div class=\"container\">\n      <div class=\"about-grid\">\n        <div class=\"about-image fade-in\"></div>\n\n        <div class=\"fade-in\">\n          <span class=\"eyebrow\">Nosotros</span>\n          <h2>Un negocio serio para un trabajo que no admite improvisaciones</h2>\n          <p>En Picturelle entendemos que un techo no se cambia todos los años. Por eso hablamos claro desde el inicio: qué encontramos, qué recomendamos y cuánto va a costar. Llevamos 10 años trabajando techos con una meta simple: dejar el problema resuelto y que usted se quede tranquilo.</p>\n          <p>No vendemos trabajos que no hacen falta. Si una reparación bien hecha le ahorra un reemplazo completo, se lo decimos. Si el techo ya llegó a su límite, también se lo explicamos con honestidad.</p>\n\n          <div class=\"about-points\">\n            <div class=\"about-point\">\n              <i data-lucide=\"circle-dollar-sign\" style=\"width:22px;height:22px;\"></i>\n              <div><strong>Precio justo desde el principio</strong><br><span class=\"muted\">Sin cambios de último minuto ni cargos que nadie le explicó.</span></div>\n            </div>\n            <div class=\"about-point\">\n              <i data-lucide=\"shield-check\" style=\"width:22px;height:22px;\"></i>\n              <div><strong>Trabajo garantizado</strong><br><span class=\"muted\">Le dejamos respaldo claro sobre lo realizado.</span></div>\n            </div>\n            <div class=\"about-point\">\n              <i data-lucide=\"message-square-more\" style=\"width:22px;height:22px;\"></i>\n              <div><strong>Comunicación directa</strong><br><span class=\"muted\">Le avisamos avances, tiempos y cualquier ajuste necesario antes de hacerlo.</span></div>\n            </div>\n          </div>\n\n          <div class=\"hours-box\">\n            <h3>Horario de atención</h3>\n            <p class=\"muted\">{{custom_values.hours_of_operation}}</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section section-alt\" id=\"proceso\">\n    <div class=\"container\">\n      <div class=\"fade-in\">\n        <span class=\"eyebrow\">Proceso</span>\n        <h2>Así trabajamos, paso por paso</h2>\n        <p class=\"muted\">Sin vueltas innecesarias. Usted llama, revisamos el techo, le damos un precio claro y hacemos el trabajo como se acordó.</p>\n      </div>\n\n      <div class=\"process-grid\">\n        <div class=\"process-step fade-in\">\n          <div class=\"step-number\">01</div>\n          <h3>Usted llama</h3>\n          <p>Cuéntenos qué está pasando: fuga, tejas dañadas, desgaste o necesidad de cambio completo.</p>\n        </div>\n\n        <div class=\"process-step fade-in\">\n          <div class=\"step-number\">02</div>\n          <h3>Revisamos y cotizamos</h3>\n          <p>Inspeccionamos el techo y le damos una propuesta clara, sin letras pequeñas.</p>\n        </div>\n\n        <div class=\"process-step fade-in\">\n          <div class=\"step-number\">03</div>\n          <h3>Usted aprueba</h3>\n          <p>Le explicamos materiales, tiempos y alcance del trabajo antes de empezar.</p>\n        </div>\n\n        <div class=\"process-step fade-in\">\n          <div class=\"step-number\">04</div>\n          <h3>Trabajo terminado</h3>\n          <p>Dejamos el área limpia, el techo resuelto y la garantía del trabajo bien definida.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section\" id=\"testimonios\">\n    <div class=\"container\">\n      <div class=\"fade-in\">\n        <span class=\"eyebrow\">Reseñas</span>\n        <h2>Lo que dicen clientes que ya nos llamaron</h2>\n        <p class=\"muted\">Testimonios realistas de trabajos de roofing donde lo importante fue resolver bien y a tiempo.</p>\n      </div>\n\n      <div class=\"testimonials-grid\">\n        <div class=\"testimonial fade-in\">\n          <div class=\"stars\">★★★★★</div>\n          <p>“Tenía una filtración que ya me había manchado el techo del pasillo. Vinieron, encontraron de dónde entraba el agua y ese mismo día dejaron la reparación lista. Después llovió fuerte y no volvió a gotear.”</p>\n          <strong>María G. — Glendale</strong>\n        </div>\n\n        <div class=\"testimonial fade-in\">\n          <div class=\"stars\">★★★★★</div>\n          <p>“Nos cambiaron varias secciones del techo de la casa y desde la cotización fueron muy claros. Me gustó que explicaron qué madera sí había que reemplazar y qué partes todavía servían. El precio final fue el mismo que me dieron.”</p>\n          <strong>Jorge R. — Burbank</strong>\n        </div>\n\n        <div class=\"testimonial fade-in\">\n          <div class=\"stars\">★★★★★</div>\n          <p>“Después de una tormenta se volaron varias tejas en mi negocio. Picturelle llegó rápido, aseguró la zona y luego hizo la reparación completa. No tuve que cerrar más tiempo del necesario.”</p>\n          <strong>Ana L. — Pasadena</strong>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"urgent-cta\">\n    <div class=\"urgent-inner fade-in\">\n      <span class=\"eyebrow\" style=\"background:rgba(255,255,255,.12);color:#fff;border-left-color:var(--accent);\">Atención rápida</span>\n      <h2>Si su techo ya está filtrando, no lo deje para después</h2>\n      <p>Una fuga pequeña hoy puede convertirse en plafones dañados, moho y reparaciones más caras. Llame ahora y le ayudamos a revisar el problema.</p>\n      <a class=\"urgent-phone\" href=\"tel:{{custom_values.company_phone}}\">{{custom_values.company_phone}}</a>\n      <div>\n        <a class=\"btn btn-accent\" href=\"tel:{{custom_values.company_phone}}\">\n          <i data-lucide=\"phone-forwarded\" style=\"width:18px;height:18px;\"></i>\n          Llamar ahora\n        </a>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section section-alt\" id=\"contacto\">\n    <div class=\"container\">\n      <div class=\"fade-in\">\n        <span class=\"eyebrow\">Contacto</span>\n        <h2>Hable con Picturelle</h2>\n        <p class=\"muted\">Si necesita una reparación, una inspección o una cotización para reemplazo de techo, aquí tiene nuestros datos y el formulario de contacto.</p>\n      </div>\n\n      <div class=\"contact-grid\">\n        <div class=\"contact-info fade-in\">\n          <h3>Información de contacto</h3>\n\n          <div class=\"contact-item\">\n            <i data-lucide=\"map-pinned\" style=\"width:22px;height:22px;\"></i>\n            <div>\n              <strong>Dirección</strong><br>\n              16 de Septiembre, Queretaro, Queretaro 76000\n            </div>\n          </div>\n\n          <div class=\"contact-item\">\n            <i data-lucide=\"phone\" style=\"width:22px;height:22px;\"></i>\n            <div>\n              <strong>Teléfono</strong><br>\n              <a href=\"tel:{{custom_values.company_phone}}\">{{custom_values.company_phone}}</a>\n            </div>\n          </div>\n\n          <div class=\"contact-item\">\n            <i data-lucide=\"mail\" style=\"width:22px;height:22px;\"></i>\n            <div>\n              <strong>Email</strong><br>\n              <a href=\"mailto:{{custom_values.automation_sender_email}}\">{{custom_values.automation_sender_email}}</a>\n            </div>\n          </div>\n\n          <div class=\"contact-item\">\n            <i data-lucide=\"clock-3\" style=\"width:22px;height:22px;\"></i>\n            <div>\n              <strong>Horarios</strong><br>\n              {{custom_values.hours_of_operation}}\n            </div>\n          </div>\n        </div>\n\n        <div class=\"contact-form fade-in\">\n          <h3>Solicite su cotización</h3>\n          <p class=\"muted\">Déjenos sus datos y una breve descripción del trabajo. Le responderemos lo antes posible.</p>\n          {{custom_values.landing_form}}\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <footer>\n    <div class=\"container\">\n      <div class=\"footer-grid\">\n        <div>\n          <div class=\"footer-logo\">\n            <img src=\"{{custom_values.logo_cuadrado}}\" alt=\"{{custom_values.company_name}}\" style=\"height:60px;width:auto;object-fit:contain;filter:brightness(0) invert(1) contrast(200%);\" onerror=\"this.style.display='none';this.nextElementSibling.style.display='block'\">\n            <span style=\"display:none;font-weight:600;color:#fff;\">{{custom_values.company_name}}</span>\n          </div>\n          <p>Picturelle ofrece servicios de roofing con trabajo garantizado, comunicación clara y precio justo para propietarios residenciales y comerciales.</p>\n        </div>\n\n        <div class=\"footer-links\">\n          <h3 style=\"color:#fff;\">Enlaces</h3>\n          <a href=\"#servicios\">Servicios</a>\n          <a href=\"#nosotros\">Nosotros</a>\n          <a href=\"#contacto\">Contacto</a>\n          <a href=\"{{custom_values.dominio_web}}/privacy-policy\">Privacy Policy</a>\n          <a href=\"{{custom_values.dominio_web}}/terms-conditions\">Terms & Conditions</a>\n        </div>\n\n        <div class=\"footer-contact\">\n          <h3 style=\"color:#fff;\">Contacto</h3>\n          <a href=\"tel:{{custom_values.company_phone}}\">{{custom_values.company_phone}}</a>\n          <a href=\"mailto:{{custom_values.automation_sender_email}}\">{{custom_values.automation_sender_email}}</a>\n          <span>16 de Septiembre, Queretaro, Queretaro 76000</span>\n        </div>\n      </div>\n    </div>\n  </footer>\n\n  <script>\n    const toggleBtn = document.querySelector('.mobile-toggle');\n    const mobileMenu = document.getElementById('mobileMenu');\n\n    if (toggleBtn && mobileMenu) {\n      toggleBtn.addEventListener('click', function () {\n        mobileMenu.classList.toggle('open');\n        const expanded = mobileMenu.classList.contains('open');\n        toggleBtn.setAttribute('aria-expanded', expanded ? 'true' : 'false');\n      });\n\n      mobileMenu.querySelectorAll('a').forEach(link => {\n        link.addEventListener('click', () => {\n          mobileMenu.classList.remove('open');\n          toggleBtn.setAttribute('aria-expanded', 'false');\n        });\n      });\n    }\n\n    document.querySelectorAll('a[href^=\"#\"]').forEach(anchor => {\n      anchor.addEventListener('click', function(e) {\n        const target = document.querySelector(this.getAttribute('href'));\n        if (target) {\n          e.preventDefault();\n          target.scrollIntoView({ behavior: 'smooth', block: 'start' });\n        }\n      });\n    });\n\n    const observer = new IntersectionObserver((entries) => {\n      entries.forEach(entry => {\n        if (entry.isIntersecting) entry.target.classList.add('visible');\n      });\n    }, { threshold: 0.12 });\n\n    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));\n\n    if (typeof lucide !== 'undefined') lucide.createIcons();\n  </script>\n</body>\n</html>"
  },
